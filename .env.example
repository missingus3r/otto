# MongoDB
MONGO_URI=mongodb+srv://USER:PASS@cluster.mongodb.net/dealr?retryWrites=true&w=majority

# Server
PORT=3000
NODE_ENV=development
SESSION_SECRET=change-me-to-a-long-random-string

# LLM agent (single model, runs in background)
OPENAI_API_KEY=sk-...
AGENT_MODEL=gpt-4o-mini
AGENT_INTERVAL_MIN=5
AGENT_ENABLED=true

# Admin bootstrap (only used on first run if no admin exists)
ADMIN_EMAIL=admin@dealr.local
ADMIN_PASSWORD=change-me

# Default language
DEFAULT_LANG=es
