# MongoDB
MONGO_URI=mongodb+srv://USER:PASS@cluster.mongodb.net/otto?retryWrites=true&w=majority

# Server
PORT=3000
NODE_ENV=development
SESSION_SECRET=change-me-to-a-long-random-string
APP_URL=http://localhost:3000

# LLM agent (single model, runs in background)
OPENAI_API_KEY=sk-...
AGENT_MODEL=gpt-4o-mini
AGENT_INTERVAL_MIN=5
AGENT_ENABLED=true

# OpenAI moderation (image NSFW + content moderation, optional, falls back if missing key)
OPENAI_MODERATION_ENABLED=true

# Admin bootstrap (only used on first run if no admin exists)
ADMIN_EMAIL=admin@otto.local
ADMIN_PASSWORD=change-me

# Default language
DEFAULT_LANG=es

# Web push (VAPID — generate with: node -e "import('web-push').then(p=>console.log(p.default.generateVAPIDKeys()))")
VAPID_PUBLIC_KEY=
VAPID_PRIVATE_KEY=
VAPID_SUBJECT=mailto:admin@otto.local

# Price baseline scraper (MercadoLibre / OLX scraping for the agent)
PRICE_SCRAPE_ENABLED=true
PRICE_SCRAPE_CACHE_HOURS=6

# SMTP (outbound email — leave SMTP_HOST blank to log to console for dev)
SMTP_HOST=
SMTP_PORT=587
SMTP_USER=
SMTP_PASS=
SMTP_FROM="otto <noreply@otto.local>"

# Account deletion grace period (days)
ACCOUNT_DELETION_GRACE_DAYS=7
