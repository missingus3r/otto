<%- include('partials/header', { pageTitle: t('auth.forgotTitle') }) %>

<main class="page" style="max-width:560px;">
<%- include('partials/flash') %>

<div class="form-card">
  <h1><%= t('auth.forgotTitle') %></h1>
  <% if (typeof error !== 'undefined' && error) { %>
    <div class="error-msg"><%= error %></div>
  <% } %>
  <% if (typeof sent !== 'undefined' && sent) { %>
    <div class="flash success"><%= t('auth.forgotSent') %></div>
  <% } else { %>
    <p class="muted"><%= t('auth.forgotIntro') %></p>
    <form action="/auth/forgot" method="post">
      <input type="hidden" name="_csrf" value="<%= csrfToken %>">
      <label for="email"><%= t('auth.email') %></label>
      <input id="email" type="email" name="email" required autocomplete="email">
      <div class="spacer"></div>
      <button class="btn block" type="submit"><%= t('auth.resetSubmit') %></button>
    </form>
  <% } %>
  <div class="spacer"></div>
  <div class="center muted">
    <a href="/auth/login">← <%= t('auth.login') %></a>
  </div>
</div>
</main>

<%- include('partials/footer') %>
