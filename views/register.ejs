<%- include('partials/header', { pageTitle: t('auth.registerTitle') }) %>
<%- include('partials/flash') %>

<div class="form-card">
  <h1><%= t('auth.registerTitle') %></h1>
  <% if (typeof error !== 'undefined' && error) { %>
    <div class="error-msg"><%= error %></div>
  <% } %>
  <form action="/auth/register" method="post">
    <label for="displayName"><%= t('auth.displayName') %></label>
    <input id="displayName" type="text" name="displayName" autocomplete="name">
    <label for="email"><%= t('auth.email') %></label>
    <input id="email" type="email" name="email" required autocomplete="email">
    <label for="password"><%= t('auth.password') %></label>
    <input id="password" type="password" name="password" required minlength="6" autocomplete="new-password">
    <div class="spacer"></div>
    <button class="btn block" type="submit"><%= t('auth.register') %></button>
  </form>
  <div class="spacer"></div>
  <div class="center muted">
    <%= t('auth.haveAccount') %> <a href="/auth/login"><%= t('auth.login') %></a>
  </div>
</div>

<%- include('partials/footer') %>
