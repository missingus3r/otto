<%- include('../partials/header', { pageTitle: t('listings.mine') }) %>
<%- include('../partials/nav', { activePage: 'listings' }) %>

<style>
  .filters { display: flex; gap: 16px; flex-wrap: wrap; align-items: center; margin-bottom: 28px; }
  .filters .seg { flex: 0 0 auto; }
  .filters .input, .filters .select { max-width: 220px; padding: 10px 14px; font-size: 13px; }
  .filters-spacer { flex: 1; }

  .listings-grid {
    display: grid;
    grid-template-columns: repeat(auto-fill, minmax(300px, 1fr));
    gap: 20px;
  }
  .listing-card {
    background: var(--ink-2);
    border: 1px solid var(--line);
    overflow: hidden;
    text-decoration: none;
    color: var(--paper);
    display: flex; flex-direction: column;
    transition: all .25s;
    position: relative;
  }
  .listing-card:hover { border-color: var(--line-2); transform: translateY(-3px); }
  .listing-photo { aspect-ratio: 4/3; background: var(--ink-3) center/cover no-repeat; position: relative; }
  .listing-photo .corner-stamp {
    position: absolute; top: 12px; left: 12px;
    background: var(--ink); padding: 4px 8px;
    font-family: 'DM Mono', monospace; font-size: 9px; letter-spacing: 0.18em;
    color: var(--ash); border: 1px solid var(--line-2);
  }
  .listing-photo .mod-stamp {
    position: absolute; top: 12px; right: 12px;
  }
  .listing-body { padding: 20px; flex: 1; display: flex; flex-direction: column; }
  .listing-title {
    font-family: 'Bodoni Moda', serif; font-style: italic; font-weight: 400;
    font-size: 21px; letter-spacing: -0.01em; line-height: 1.2;
    margin-bottom: 8px;
  }
  .listing-region {
    font-family: 'DM Mono', monospace; font-size: 10px;
    letter-spacing: 0.14em; text-transform: uppercase; color: var(--ash);
    margin-bottom: 14px;
  }
  .listing-range {
    font-family: 'DM Mono', monospace; font-size: 13px;
    color: var(--amber); margin-bottom: 12px;
  }
  .listing-meta {
    display: flex; justify-content: space-between; align-items: center;
    margin-top: auto;
    padding-top: 14px; border-top: 1px dotted var(--line);
    font-family: 'DM Mono', monospace; font-size: 10px; letter-spacing: 0.1em; color: var(--ash);
  }
</style>

<%
  function imgFor(l) {
    if (l.photos && l.photos.length) return l.photos[0].thumbPath || l.photos[0].path || '';
    return l.thumbPath || l.photoPath || '';
  }
  function modChip(m) {
    if (m === 'approved') return '<span class="chip green"><span class="dot"></span>approved</span>';
    if (m === 'pending') return '<span class="chip amber"><span class="dot"></span>pending</span>';
    if (m === 'rejected' || m === 'flagged') return '<span class="chip blood"><span class="dot"></span>' + m + '</span>';
    return '';
  }
  function kindLabel(t) {
    if (t === 'sell') return 'VENDO';
    if (t === 'buy') return 'BUSCO';
    if (t === 'swap' || t === 'trade') return 'TRUEQUE';
    return (t || '').toUpperCase();
  }
%>

<main class="page">
  <%- include('../partials/flash') %>
  <div id="banner-slot"></div>

  <header class="page-header">
    <div class="lead">
      <div class="page-eyebrow">Expedientes</div>
      <h1 class="page-title">Listings.</h1>
      <p class="page-sub">Lo tuyo, lo del resto. El agente está mirando todo lo que esté en <em>open</em>.</p>
    </div>
    <a class="btn" href="/listings/new">+ <%= t('listings.new') %> <span class="arrow">→</span></a>
  </header>

  <!-- ── MIS LISTINGS ── -->
  <section style="margin-bottom:48px;">
    <div class="page-eyebrow" style="margin-bottom:18px;"><%= t('listings.mine') %></div>

    <% if (!mine || mine.length === 0) { %>
      <div class="empty">
        <div class="glyph">∅</div>
        <h3><%= t('listings.empty') %></h3>
        <p>Publicá tu primer expediente y el agente arranca.</p>
        <a class="btn sm" href="/listings/new">+ <%= t('listings.new') %></a>
      </div>
    <% } else { %>
      <div class="listings-grid">
        <% mine.forEach(function(l) { var img = imgFor(l); %>
          <a class="listing-card" href="/listings/<%= l._id %>">
            <div class="listing-photo"<% if (img) { %> style="background-image:url('<%= img %>')"<% } %>>
              <span class="corner-stamp">#<%= String(l._id).slice(-6) %> · <%= kindLabel(l.type) %></span>
              <span class="mod-stamp"><%- modChip(l.moderationStatus) %></span>
            </div>
            <div class="listing-body">
              <div class="listing-title"><%= l.title %></div>
              <div class="listing-region"><%= l.city || '—' %></div>
              <% if (l.type !== 'swap') { %>
                <div class="listing-range"><%= formatPriceRange(l.priceMin, l.priceMax, l.currency) %></div>
              <% } else { %>
                <div class="listing-range">— TRUEQUE —</div>
              <% } %>
              <div class="listing-meta">
                <span><%= (l.status || '').toUpperCase() %></span>
                <% if (l.category) { %><span><%= t('category.' + l.category) %></span><% } %>
              </div>
            </div>
          </a>
        <% }); %>
      </div>
    <% } %>
  </section>

  <!-- ── EXPLORAR ── -->
  <section>
    <div class="page-eyebrow" style="margin-bottom:18px;"><%= t('listings.explore') %></div>

    <form method="get" action="/listings" class="filters">
      <input class="input" type="search" name="q" value="<%= filters && filters.q || '' %>" placeholder="<%= t('listings.searchPlaceholder') %>">
      <select class="select" name="type">
        <option value=""><%= t('listings.allTypes') %></option>
        <option value="sell"<%= (filters && filters.type === 'sell') ? ' selected' : '' %>><%= t('listings.type.sell') %></option>
        <option value="swap"<%= (filters && filters.type === 'swap') ? ' selected' : '' %>><%= t('listings.type.swap') %></option>
        <option value="buy"<%= (filters && filters.type === 'buy') ? ' selected' : '' %>><%= t('listings.type.buy') %></option>
      </select>
      <select class="select" name="category">
        <option value=""><%= t('listings.allCategories') %></option>
        <% (categories || []).forEach(function(c) { %>
          <option value="<%= c %>"<%= (filters && filters.category === c) ? ' selected' : '' %>><%= t('category.' + c) %></option>
        <% }); %>
      </select>
      <input class="input" type="number" min="0" step="0.01" name="min" value="<%= filters && filters.min !== '' ? filters.min : '' %>" placeholder="<%= t('listings.priceMin') %>">
      <input class="input" type="number" min="0" step="0.01" name="max" value="<%= filters && filters.max !== '' ? filters.max : '' %>" placeholder="<%= t('listings.priceMax') %>">
      <input class="input" type="text" name="city" value="<%= filters && filters.city || '' %>" placeholder="<%= t('listings.city') %>">
      <div class="filters-spacer"></div>
      <button class="btn ghost sm" type="submit"><%= t('listings.applyFilters') %></button>
      <a class="btn ghost sm" href="/listings"><%= t('listings.clearFilters') %></a>
    </form>

    <% if (!explore || explore.length === 0) { %>
      <div class="empty">
        <div class="glyph">∅</div>
        <h3><%= t('listings.exploreEmpty') %></h3>
        <p>El expediente está vacío. Probá quitando filtros.</p>
      </div>
    <% } else { %>
      <div class="listings-grid">
        <% explore.forEach(function(l) { var img = imgFor(l); %>
          <a class="listing-card" href="/listings/<%= l._id %>">
            <div class="listing-photo"<% if (img) { %> style="background-image:url('<%= img %>')"<% } %>>
              <span class="corner-stamp">#<%= String(l._id).slice(-6) %> · <%= kindLabel(l.type) %></span>
            </div>
            <div class="listing-body">
              <div class="listing-title"><%= l.title %></div>
              <div class="listing-region"><%= l.city || '—' %></div>
              <% if (l.type !== 'swap') { %>
                <div class="listing-range"><%= formatPriceRange(l.priceMin, l.priceMax, l.currency) %></div>
              <% } else { %>
                <div class="listing-range">— TRUEQUE —</div>
              <% } %>
              <div class="listing-meta">
                <% if (l.category) { %><span><%= t('category.' + l.category) %></span><% } else { %><span></span><% } %>
                <span></span>
              </div>
            </div>
          </a>
        <% }); %>
      </div>
    <% } %>
  </section>
</main>

<%- include('../partials/footer') %>
