<%- include('../partials/header', { pageTitle: t('listings.edit') }) %>
<%- include('../partials/nav', { activePage: 'listings' }) %>

<main class="page">
<%- include('../partials/flash') %>

<div class="form-card">
  <h1><%= t('listings.edit') %></h1>
  <% if (typeof error !== 'undefined' && error) { %>
    <div class="error-msg"><%= error %></div>
  <% } %>

  <form action="/listings/<%= listing._id %>/edit" method="post" enctype="multipart/form-data">
    <input type="hidden" name="_csrf" value="<%= csrfToken %>">

    <label for="title"><%= t('listings.title') %></label>
    <input id="title" name="title" type="text" required maxlength="120" value="<%= listing.title %>">

    <label for="description"><%= t('listings.description') %></label>
    <textarea id="description" name="description" maxlength="2000"><%= listing.description %></textarea>

    <label for="category"><%= t('listings.category') %></label>
    <select id="category" name="category">
      <% (categories || []).forEach(function(c) { %>
        <option value="<%= c %>"<%= listing.category === c ? ' selected' : '' %>><%= t('category.' + c) %></option>
      <% }); %>
    </select>

    <div class="row" style="gap:12px;">
      <div style="flex:1;">
        <label for="priceMin"><%= t('listings.priceMin') %></label>
        <input id="priceMin" type="number" name="priceMin" min="0" step="0.01" value="<%= listing.priceMin %>">
      </div>
      <div style="flex:1;">
        <label for="priceMax"><%= t('listings.priceMax') %></label>
        <input id="priceMax" type="number" name="priceMax" min="0" step="0.01" value="<%= listing.priceMax %>">
      </div>
    </div>

    <label for="currency"><%= t('listings.currency') %></label>
    <select id="currency" name="currency">
      <% ['UYU','USD','BRL','ARS','EUR'].forEach(function(c) { %>
        <option value="<%= c %>"<%= listing.currency === c ? ' selected' : '' %>><%= c %></option>
      <% }); %>
    </select>

    <label for="city"><%= t('listings.city') %></label>
    <input id="city" type="text" name="city" maxlength="80" value="<%= listing.city || '' %>">

    <% if (listing.type === 'swap') { %>
      <label for="swapForDescription"><%= t('listings.swapFor') %></label>
      <textarea id="swapForDescription" name="swapForDescription" maxlength="500"><%= listing.swapForDescription || '' %></textarea>
    <% } %>

    <label for="photos"><%= t('listings.photos') %> — <%= t('common.optional') %> (replaces existing)</label>
    <input id="photos" type="file" name="photos" accept="image/*" multiple>

    <div class="spacer"></div>
    <div class="btn-row">
      <button class="btn block" type="submit"><%= t('listings.save') %></button>
      <a class="btn ghost block" href="/listings/<%= listing._id %>"><%= t('common.cancel') %></a>
    </div>
  </form>
</div>
</main>

<%- include('../partials/footer') %>
