<%- include('../partials/header', { pageTitle: t('listings.new') }) %>
<%- include('../partials/nav', { activePage: 'new' }) %>

<style>
  .form-grid { display: grid; grid-template-columns: 1.4fr 1fr; gap: 56px; }
  .form-aside { position: sticky; top: 100px; align-self: start; }
  .pipeline {
    background: var(--ink-2); border: 1px solid var(--line); padding: 24px;
    font-family: 'DM Mono', monospace; font-size: 12px; line-height: 1.7; color: var(--paper-2);
  }
  .pipeline h4 { font-family: 'DM Mono', monospace; font-size: 11px; letter-spacing: 0.2em; color: var(--blood); text-transform: uppercase; margin-bottom: 16px; }
  .pipeline ol { list-style: none; counter-reset: step; }
  .pipeline li { counter-increment: step; padding: 8px 0 8px 32px; position: relative; border-bottom: 1px dotted var(--line); }
  .pipeline li:last-child { border-bottom: none; }
  .pipeline li::before { content: counter(step, decimal-leading-zero); position: absolute; left: 0; top: 8px; color: var(--blood); font-weight: 500; }
  .pipeline code { color: var(--amber); }
  .photo-drop {
    border: 1px dashed var(--line-2);
    background: rgba(0,0,0,0.3);
    padding: 32px; text-align: center;
    cursor: pointer; transition: all .2s;
  }
  .photo-drop:hover { border-color: var(--paper); background: rgba(0,0,0,0.45); }
  .photo-drop .glyph { font-family: 'Bodoni Moda', serif; font-style: italic; font-size: 48px; color: var(--smoke); margin-bottom: 8px; }
  .photo-drop p { font-family: 'DM Mono', monospace; font-size: 11px; letter-spacing: 0.1em; color: var(--ash); text-transform: uppercase; }
  .kind-radio { display: grid; grid-template-columns: repeat(3, 1fr); gap: 0; border: 1px solid var(--line-2); }
  .kind-radio label {
    padding: 14px; text-align: center; cursor: pointer;
    border-right: 1px solid var(--line-2);
    font-family: 'DM Mono', monospace; font-size: 11px; letter-spacing: 0.14em; text-transform: uppercase;
    color: var(--ash);
    transition: all .2s;
    margin: 0;
  }
  .kind-radio label:last-child { border-right: none; }
  .kind-radio input { display: none; }
  .kind-radio label:hover { color: var(--paper); }
  .kind-radio label:has(input:checked) { background: var(--blood); color: var(--paper); }
  @media (max-width: 980px) { .form-grid { grid-template-columns: 1fr; } .form-aside { position: static; } }
</style>

<main class="page">
  <header class="page-header">
    <div class="lead">
      <div class="page-eyebrow"><a href="/listings" style="color:var(--ash);text-decoration:none;">← <%= t('nav.listings') %></a></div>
      <h1 class="page-title">Nuevo <em>expediente.</em></h1>
      <p class="page-sub">Definí qué, cuánto y en qué rango. El agente arranca a escanear apenas guardes.</p>
    </div>
  </header>

  <%- include('../partials/flash') %>
  <div id="banner-slot"></div>

  <% if (typeof error !== 'undefined' && error) { %>
    <div class="banner">
      <div class="banner-stamp">ERR</div>
      <div class="banner-body">
        <div class="banner-title">Error</div>
        <div class="banner-text"><%= error %></div>
      </div>
    </div>
  <% } %>

  <% if (typeof blocked !== 'undefined' && blocked) { %>
    <div class="banner warn">
      <div class="banner-stamp">VERIFY</div>
      <div class="banner-body">
        <div class="banner-title"><%= t('verify.required') %></div>
        <div class="banner-text">Mandamos un mail con un link de verificación. Revisá tu bandeja.</div>
        <form action="/auth/verify/resend" method="post" style="margin-top:10px;">
          <input type="hidden" name="_csrf" value="<%= csrfToken %>">
          <button class="btn ghost sm" type="submit"><%= t('verify.resend') %></button>
        </form>
      </div>
    </div>
  <% } else { %>
    <div class="form-grid">
      <form id="new-form" action="/listings" method="post" enctype="multipart/form-data" novalidate>
        <input type="hidden" name="_csrf" value="<%= csrfToken %>">

        <div class="field">
          <label>Tipo de operación <span class="req">*</span></label>
          <div class="kind-radio">
            <label><input type="radio" name="type" value="sell" checked><span><%= t('listings.type.sell') %></span></label>
            <label><input type="radio" name="type" value="buy"><span><%= t('listings.type.buy') %></span></label>
            <label><input type="radio" name="type" value="swap"><span><%= t('listings.type.swap') %></span></label>
          </div>
        </div>

        <div class="field" id="f-title">
          <label for="title"><%= t('listings.title') %> <span class="req">*</span></label>
          <input class="input" type="text" name="title" id="title" maxlength="120" required placeholder="Ej: Polaroid SX-70 vintage funcionando">
          <div class="hint">3–120 caracteres · sanitize: strip HTML, escape unicode</div>
          <div class="field-error">requerido, mínimo 3 caracteres</div>
        </div>

        <div class="field" id="f-desc">
          <label for="description"><%= t('listings.description') %></label>
          <textarea class="textarea" name="description" id="description" maxlength="2000" rows="5" placeholder="Estado, accesorios incluidos, motivo de venta…"></textarea>
          <div class="hint">hasta 2000 caracteres · auto-flag si matchea regex de spam/contacto externo</div>
        </div>

        <div class="field">
          <label for="photos"><%= t('listings.photos') %></label>
          <div class="photo-drop" onclick="document.getElementById('photos').click()">
            <div class="glyph">+</div>
            <p>Click para seleccionar · jpg/png/webp · máx 5MB</p>
            <p style="margin-top:6px; color:var(--smoke);">multer → sharp → thumbnail (fire-and-forget)</p>
          </div>
          <input id="photos" type="file" name="photos" accept="image/*" multiple style="display:none;">
          <div class="hint">opcional pero recomendado · score de match cae sin foto</div>
        </div>

        <div class="input-row">
          <div class="field" id="f-category">
            <label for="category"><%= t('listings.category') %></label>
            <select class="select" name="category" id="category">
              <% (categories || []).forEach(function(c) { %>
                <option value="<%= c %>"<%= c === 'otros' ? ' selected' : '' %>><%= t('category.' + c) %></option>
              <% }); %>
            </select>
          </div>
          <div class="field" id="f-currency">
            <label for="currency"><%= t('listings.currency') %> <span class="req">*</span></label>
            <select class="select" name="currency" id="currency" required>
              <option value="UYU">UYU</option>
              <option value="USD">USD</option>
              <option value="BRL">BRL</option>
              <option value="ARS">ARS</option>
              <option value="EUR">EUR</option>
            </select>
          </div>
        </div>

        <div class="input-row">
          <div class="field" id="f-min">
            <label for="priceMin"><%= t('listings.priceMin') %> <span class="req">*</span></label>
            <input class="input" type="number" name="priceMin" id="priceMin" min="0" step="0.01" value="0" required>
            <div class="hint">el agente nunca propondrá nada por debajo</div>
            <div class="field-error">debe ser ≥ 0</div>
          </div>
          <div class="field" id="f-max">
            <label for="priceMax"><%= t('listings.priceMax') %> <span class="req">*</span></label>
            <input class="input" type="number" name="priceMax" id="priceMax" min="0" step="0.01" value="0" required>
            <div class="hint">si te pagan esto o más, lo cierra rápido</div>
            <div class="field-error">debe ser ≥ piso</div>
          </div>
        </div>

        <div class="field">
          <label for="city"><%= t('listings.cityOptional') %></label>
          <input class="input" type="text" name="city" id="city" maxlength="80" value="<%= currentUser && currentUser.city ? currentUser.city : '' %>">
        </div>

        <div class="field" id="swapForWrap" style="display:none;">
          <label for="swapForDescription"><%= t('listings.swapFor') %></label>
          <textarea class="textarea" name="swapForDescription" id="swapForDescription" maxlength="500"></textarea>
          <div class="hint">solo se usa si tipo = <%= t('listings.type.swap') %></div>
        </div>

        <div style="display:flex; gap:12px; margin-top:32px; flex-wrap:wrap;">
          <button class="btn" type="submit"><%= t('listings.submit') %> <span class="arrow">→</span></button>
          <a class="btn ghost" href="/listings">Cancelar</a>
        </div>
      </form>

      <aside class="form-aside">
        <div class="pipeline">
          <h4>Pipeline POST /listings</h4>
          <ol>
            <li><code>multer</code> recibe foto → temp dir</li>
            <li><code>sanitize</code> strip HTML, normalize unicode</li>
            <li><code>auto-flag</code> regex spam / contacto externo</li>
            <li><code>create()</code> → MongoDB con <code>moderation: pending|approved</code></li>
            <li><code>thumb</code> sharp resize (fire-and-forget, no bloquea)</li>
            <li><code>302 redirect</code> a <code>/listings</code></li>
          </ol>
        </div>
        <div class="pipeline" style="margin-top:16px;">
          <h4>Defaults</h4>
          <div class="kv-row"><div class="k">status</div><div class="v">draft → open al publicar</div></div>
          <div class="kv-row"><div class="k">moderation</div><div class="v">pending → approved si pasa flag</div></div>
          <div class="kv-row"><div class="k">currency</div><div class="v">infiere por región</div></div>
          <div class="kv-row"><div class="k">visibility</div><div class="v">público al aprobarse</div></div>
        </div>
      </aside>
    </div>
  <% } %>
</main>

<script>
  (function () {
    var form = document.getElementById('new-form');
    if (!form) return;
    function validate() {
      document.querySelectorAll('.field').forEach(function (f) { f.classList.remove('error'); });
      var d = Object.fromEntries(new FormData(form));
      var ok = true;
      if (!d.title || d.title.length < 3) { document.getElementById('f-title').classList.add('error'); ok = false; }
      if (d.priceMin === '' || +d.priceMin < 0) { document.getElementById('f-min').classList.add('error'); ok = false; }
      if (d.priceMax === '' || +d.priceMax < +d.priceMin) { document.getElementById('f-max').classList.add('error'); ok = false; }
      return ok;
    }
    form.addEventListener('submit', function (e) {
      if (!validate()) {
        e.preventDefault();
        ottoBanner({ kind: 'error', stamp: '422', title: 'Revisá los campos marcados', text: 'Algunos campos no pasaron validación cliente.' });
      }
    });
  })();
</script>

<%- include('../partials/footer') %>
