<%- include('partials/header', { pageTitle: t('app.name') }) %>

<section class="hero">
  <h1><%= t('landing.hero.title') %></h1>
  <p><%= t('landing.hero.subtitle') %></p>
  <div class="cta-row">
    <a class="btn" href="/auth/register"><%= t('landing.cta.primary') %></a>
    <a class="btn secondary" href="/auth/login"><%= t('landing.cta.secondary') %></a>
  </div>
</section>

<section class="features">
  <div class="feature">
    <div class="feature-icon">1</div>
    <h3><%= t('landing.feature1.title') %></h3>
    <p><%= t('landing.feature1.body') %></p>
  </div>
  <div class="feature">
    <div class="feature-icon">2</div>
    <h3><%= t('landing.feature2.title') %></h3>
    <p><%= t('landing.feature2.body') %></p>
  </div>
  <div class="feature">
    <div class="feature-icon">3</div>
    <h3><%= t('landing.feature3.title') %></h3>
    <p><%= t('landing.feature3.body') %></p>
  </div>
</section>

<h2 class="section-title"><%= t('landing.how.title') %></h2>
<section class="steps">
  <div class="step">
    <span class="num">1</span>
    <p><%= t('landing.how.step1') %></p>
  </div>
  <div class="step">
    <span class="num">2</span>
    <p><%= t('landing.how.step2') %></p>
  </div>
  <div class="step">
    <span class="num">3</span>
    <p><%= t('landing.how.step3') %></p>
  </div>
</section>

<div class="spacer"></div>
<div class="center">
  <a class="btn" href="/auth/register"><%= t('landing.cta.primary') %></a>
</div>

<%- include('partials/footer') %>
