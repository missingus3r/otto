<%- include('../partials/header', { pageTitle: t('admin.agentLog') }) %>
<%- include('../partials/nav') %>

<a class="muted" href="/admin">← <%= t('common.back') %></a>
<h1 class="section-title" style="margin-top:8px"><%= t('admin.agentLog') %></h1>

<div class="card">
  <strong><%= t('admin.agent.status') %>:</strong>
  <% if (agentPaused) { %>
    <span class="pill cancelled"><%= t('admin.agent.paused') %></span>
  <% } else { %>
    <span class="pill open"><%= t('admin.agent.running') %></span>
  <% } %>
</div>

<div class="table-wrap card" style="padding:0;">
  <table>
    <thead>
      <tr>
        <th>Started</th>
        <th>Finished</th>
        <th>Scanned</th>
        <th>Proposed</th>
        <th>Tokens</th>
        <th>Error</th>
      </tr>
    </thead>
    <tbody>
      <% logs.forEach(function(l) { %>
        <tr>
          <td style="font-size:0.8rem"><%= new Date(l.startedAt).toLocaleString() %></td>
          <td style="font-size:0.8rem"><%= l.finishedAt ? new Date(l.finishedAt).toLocaleString() : '—' %></td>
          <td><%= l.listingsScanned %></td>
          <td><%= l.matchesProposed %></td>
          <td><%= l.llmTokensUsed %></td>
          <td style="color:#dc2626;font-size:0.8rem;max-width:240px;overflow:auto;"><%= l.error || '' %></td>
        </tr>
      <% }); %>
    </tbody>
  </table>
</div>
<%- include('../partials/pager') %>

<%- include('../partials/footer') %>
