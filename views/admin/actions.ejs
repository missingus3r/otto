<%- include('../partials/header', { pageTitle: t('admin.actions') }) %>
<%- include('../partials/nav', { activePage: 'admin' }) %>

<main class="page">
<a class="muted" href="/admin">← <%= t('common.back') %></a>
<h1 class="section-title" style="margin-top:8px"><%= t('admin.actions') %></h1>

<% if (!actions || actions.length === 0) { %>
  <div class="card muted"><%= t('admin.actions.empty') %></div>
<% } else { %>
  <div class="table-wrap card" style="padding:0;">
    <table>
      <thead>
        <tr>
          <th>When</th>
          <th>Admin</th>
          <th>Action</th>
          <th>Target</th>
          <th>Data</th>
        </tr>
      </thead>
      <tbody>
        <% actions.forEach(function(a) { %>
          <tr>
            <td style="font-size:0.8rem"><%= new Date(a.createdAt).toLocaleString() %></td>
            <td><%= a.adminId ? (a.adminId.displayName || a.adminId.email) : '—' %></td>
            <td><span class="pill"><%= a.action %></span></td>
            <td style="font-family:monospace;font-size:0.75rem;"><%= a.targetType %>:<%= a.targetId ? a.targetId.slice(-6) : '' %></td>
            <td style="font-family:monospace;font-size:0.75rem;max-width:280px;overflow:auto;"><%= JSON.stringify(a.data || {}) %></td>
          </tr>
        <% }); %>
      </tbody>
    </table>
  </div>
  <%- include('../partials/pager') %>
<% } %>
</main>

<%- include('../partials/footer') %>
