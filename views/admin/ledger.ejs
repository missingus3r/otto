<%- include('../partials/header', { pageTitle: t('admin.ledger') }) %>
<%- include('../partials/nav') %>

<a class="muted" href="/admin">← <%= t('common.back') %></a>
<h1 class="section-title" style="margin-top:8px"><%= t('admin.ledger') %></h1>
<p class="muted">Append-only audit trail.</p>

<div class="table-wrap card" style="padding:0;">
  <table>
    <thead>
      <tr>
        <th>When</th>
        <th>Action</th>
        <th>Tx</th>
        <th>Data</th>
      </tr>
    </thead>
    <tbody>
      <% entries.forEach(function(e) { %>
        <tr>
          <td style="font-size:0.8rem"><%= new Date(e.createdAt).toLocaleString() %></td>
          <td><span class="pill"><%= e.action %></span></td>
          <td style="font-family:monospace;font-size:0.75rem;"><%= e.transactionId ? String(e.transactionId).slice(-6) : '—' %></td>
          <td style="font-family:monospace;font-size:0.75rem;max-width:320px;overflow:auto;"><%= JSON.stringify(e.data) %></td>
        </tr>
      <% }); %>
    </tbody>
  </table>
</div>

<%- include('../partials/footer') %>
