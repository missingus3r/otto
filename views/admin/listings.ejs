<%- include('../partials/header', { pageTitle: t('admin.listings') }) %>
<%- include('../partials/nav') %>

<a class="muted" href="/admin">← <%= t('common.back') %></a>
<h1 class="section-title" style="margin-top:8px"><%= t('admin.listings') %></h1>

<div class="table-wrap card" style="padding:0;">
  <table>
    <thead>
      <tr>
        <th>Título</th>
        <th>Tipo</th>
        <th>Estado</th>
        <th>Rango</th>
        <th>Owner</th>
        <th>Fecha</th>
      </tr>
    </thead>
    <tbody>
      <% listings.forEach(function(l) {
           var img = (l.photos && l.photos.length) ? (l.photos[0].thumbPath || l.photos[0].path) : (l.thumbPath || l.photoPath || '');
      %>
        <tr>
          <td>
            <% if (img) { %><img src="<%= img %>" alt="" style="width:32px;height:32px;object-fit:cover;border-radius:4px;vertical-align:middle;margin-right:6px;"><% } %>
            <a href="/listings/<%= l._id %>"><%= l.title %></a>
          </td>
          <td><span class="pill <%= l.type %>"><%= t('listings.type.' + l.type) %></span></td>
          <td><span class="pill <%= l.status %>"><%= t('listings.status.' + l.status) %></span></td>
          <td><%= formatPriceRange(l.priceMin, l.priceMax, l.currency) %></td>
          <td style="font-size:0.85rem"><%= l.userId ? (l.userId.displayName || l.userId.email) : '—' %></td>
          <td style="font-size:0.8rem"><%= new Date(l.createdAt).toLocaleDateString() %></td>
        </tr>
      <% }); %>
    </tbody>
  </table>
</div>
<%- include('../partials/pager') %>

<%- include('../partials/footer') %>
